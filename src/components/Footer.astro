---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <p>&copy; {year} David Navrátil</p>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-md) 0;
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-xl);
  }
  .footer-inner {
    text-align: center;
  }
  p {
    font-size: 0.85rem;
    color: var(--color-muted);
  }
</style>
