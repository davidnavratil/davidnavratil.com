---
import { useTranslations } from '../i18n/utils';

const t = useTranslations(Astro.currentLocale);
const year = new Date().getFullYear();
---

<div class="footer-cta-wrapper">
  <div class="container">
    <div class="footer-cta">
      <h2 set:html={t('footer.cta.title')} />
      <p set:html={t('footer.cta.desc')} />
      <a href="#newsletter" class="footer-cta-btn">
        {t('footer.cta.button')}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</div>

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <span class="footer-mark">DN</span>
      <p>&copy; {year} David Navrátil</p>
    </div>
    <div class="footer-links">
      <a href="https://davidnavratil.substack.com" target="_blank" rel="noopener">Substack</a>
      <a href="https://www.linkedin.com/in/david-navratil/" target="_blank" rel="noopener">LinkedIn</a>
    </div>
  </div>
</footer>

<style>
  .footer-cta-wrapper {
    margin-top: var(--space-2xl);
    margin-bottom: 0;
  }
  .footer-cta {
    text-align: center;
    padding: var(--space-2xl) var(--space-lg);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }
  .footer-cta h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 2.5vw, 1.7rem);
    color: var(--color-text);
    margin-bottom: var(--space-xs);
    line-height: 1.3;
  }
  .footer-cta p {
    color: var(--color-text-secondary);
    font-size: 1rem;
    margin-bottom: var(--space-md);
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }
  .footer-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
    background: var(--gradient-accent);
    color: white;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 15px var(--color-accent-glow);
  }
  .footer-cta-btn:hover {
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px var(--color-accent-glow);
  }

  .footer {
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-xl);
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .footer-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 6px;
    background: var(--color-border);
    color: var(--color-muted);
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 0.65rem;
    letter-spacing: 0.05em;
  }
  .footer-left p {
    font-size: 0.85rem;
    color: var(--color-muted);
  }
  .footer-links {
    display: flex;
    gap: var(--space-md);
  }
  .footer-links a {
    font-size: 0.85rem;
    color: var(--color-muted);
    transition: color 0.2s;
  }
  .footer-links a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .footer-inner { flex-direction: column; gap: var(--space-sm); }
    .footer-cta { padding: var(--space-xl) var(--space-md); }
    .footer-cta-btn {
      min-height: 44px;
    }
  }
</style>
