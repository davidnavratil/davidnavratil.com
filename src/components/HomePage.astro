---
import Base from '../layouts/Base.astro';
import NewsletterCTA from './NewsletterCTA.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations(Astro.currentLocale);
const locale = Astro.currentLocale ?? 'cs';
---

<Base title={t('meta.title')} description={t('meta.description')}>

  <!-- ========== HERO ========== -->
  <section class="hero">
    <div class="hero-bg">
      <div class="grid-pattern"></div>
      <div class="hero-glow"></div>
    </div>
    <div class="container hero-grid">
      <div class="hero-content">
        <div class="hero-role">
          <span class="role-dot"></span>
          {t('hero.role')}
        </div>
        <h1 class="hero-title">
          {t('hero.title.1')}<br/>
          <span class="gradient-text">{t('hero.title.2')}</span>
        </h1>
        <p class="hero-sub">{t('hero.sub')}</p>
        <div class="hero-cta">
          <a href="#analyzy" class="btn-primary">
            {t('hero.cta.primary')}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="https://davidnavratil.substack.com" target="_blank" rel="noopener" class="btn-secondary">
            {t('hero.cta.secondary')}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
          </a>
        </div>
      </div>
      <div class="hero-photo-wrap">
        <div class="hero-photo">
          <img src="/images/david-portrait.jpg" alt="David Navrátil" width="420" height="420" loading="eager" />
        </div>
        <div class="photo-accent"></div>
      </div>
    </div>
  </section>

  <!-- ========== TRUST BAR ========== -->
  <section class="trust-bar reveal">
    <div class="container">
      <p class="trust-label">{t('trust.label')}</p>
      <div class="trust-logos">
        <span class="trust-logo">Bloomberg</span>
        <span class="trust-logo-sep"></span>
        <span class="trust-logo">Financial Times</span>
        <span class="trust-logo-sep"></span>
        <span class="trust-logo">Reuters</span>
        <span class="trust-logo-sep"></span>
        <span class="trust-logo">ČT24</span>
        <span class="trust-logo-sep"></span>
        <span class="trust-logo">Český rozhlas</span>
        <span class="trust-logo-sep"></span>
        <span class="trust-logo">HN</span>
        <span class="trust-logo-sep"></span>
        <span class="trust-logo">Seznam Zprávy</span>
        <span class="trust-logo-sep"></span>
        <span class="trust-logo">CzechCrunch</span>
        <span class="trust-logo-sep"></span>
        <span class="trust-logo">Euromoney</span>
      </div>
    </div>
  </section>

  <!-- ========== METRICS ========== -->
  <section class="metrics container reveal">
    <div class="metrics-grid">
      <div class="metric">
        <span class="metric-value" data-count="15">15+</span>
        <span class="metric-label">{t('metrics.years.label')}</span>
      </div>
      <div class="metric-divider"></div>
      <div class="metric">
        <span class="metric-value">6</span>
        <span class="metric-label">{t('metrics.analyses.label')}</span>
      </div>
      <div class="metric-divider"></div>
      <div class="metric">
        <span class="metric-value" data-count="700">700+</span>
        <span class="metric-label">{t('metrics.articles.label')}</span>
      </div>
    </div>
  </section>

  <!-- ========== ANALYSES ========== -->
  <section class="analyses container" id="analyzy">
    <div class="section-header reveal">
      <div class="section-tag">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M7 16l4-8 4 4 6-10"/></svg>
        {t('analyses.title')}
      </div>
      <h2>{t('analyses.subtitle')}</h2>
    </div>

    <!-- Featured analysis — Hormuz -->
    <a href={locale === 'en' ? '/analyses/hormuz/en/' : '/analyses/hormuz/'} class="analysis-featured reveal">
      <div class="featured-visual">
        <div class="featured-screenshot">
          <img src="/images/preview-hormuz.png" alt={t('analyses.hormuz.title')} loading="lazy" />
        </div>
        <div class="featured-overlay"></div>
      </div>
      <div class="featured-content">
        <div class="card-badge">{t('card.badge.live')}</div>
        <h3>{t('analyses.hormuz.title')}</h3>
        <p set:html={t('analyses.hormuz.desc')} />
        <div class="card-tags">
          <span>{t('tag.geopolitics')}</span>
          <span>{t('tag.energy')}</span>
          <span>{t('tag.supply')}</span>
        </div>
        <span class="card-link">
          {t('analyses.explore')}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
      </div>
    </a>

    <!-- Secondary analyses grid -->
    <div class="analysis-grid">
      <a href={locale === 'en' ? '/analyses/ree-dashboard/en/' : '/analyses/ree-dashboard/cs/'} class="analysis-card reveal">
        <div class="card-screenshot">
          <img src="/images/preview-ree.png" alt={t('analyses.ree.title')} loading="lazy" />
        </div>
        <div class="card-body">
          <h3>{t('analyses.ree.title')}</h3>
          <p set:html={t('analyses.ree.desc')} />
          <div class="card-tags">
            <span>{t('tag.minerals')}</span>
            <span>{t('tag.china')}</span>
            <span>{t('tag.tech')}</span>
          </div>
          <span class="card-link">
            {t('analyses.explore')}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </div>
      </a>
      <a href="/analyses/uzka-hrdla/" class="analysis-card reveal reveal-delay-1">
        <div class="card-screenshot">
          <img src="/images/preview-chokepoints.png" alt={t('analyses.chokepoints.title')} loading="lazy" />
        </div>
        <div class="card-body">
          <h3>{t('analyses.chokepoints.title')}</h3>
          <p set:html={t('analyses.chokepoints.desc')} />
          <div class="card-tags">
            <span>{t('tag.maps')}</span>
            <span>{t('tag.trade')}</span>
            <span>{t('tag.risks')}</span>
          </div>
          <span class="card-link">
            {t('analyses.explore')}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </div>
      </a>
    </div>
  </section>

  <!-- ========== SPEAKING & MEDIA ========== -->
  <section class="speaking container" id="speaking">
    <div class="speaking-layout reveal">
      <div class="speaking-content">
        <div class="section-tag">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
          {t('speaking.title')}
        </div>
        <h2>{t('speaking.desc')}</h2>
        <div class="speaking-stats">
          <div class="speaking-stat">
            <span class="stat-value">{t('speaking.stat1.value')}</span>
            <span class="stat-label">{t('speaking.stat1.label')}</span>
          </div>
          <div class="speaking-stat">
            <span class="stat-value">{t('speaking.stat2.value')}</span>
            <span class="stat-label">{t('speaking.stat2.label')}</span>
          </div>
        </div>
        <a href="#kontakt" class="btn-primary">
          {t('speaking.cta')}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="speaking-gallery">
        <div class="gallery-item gallery-large">
          <img src="/images/david-keynote.jpg" alt="Keynote" loading="lazy" />
        </div>
        <div class="gallery-item gallery-small-top">
          <img src="/images/david-data.jpg" alt="Data presentation" loading="lazy" />
        </div>
        <div class="gallery-item gallery-small-bottom">
          <img src="/images/david-speaking.jpg" alt="Panel discussion" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ========== NEWSLETTER CTA ========== -->
  <NewsletterCTA />

  <!-- ========== ABOUT ========== -->
  <section class="about container" id="about">
    <div class="about-grid reveal">
      <div class="about-photo-col">
        <div class="about-photo">
          <img src="/images/david-panel.jpg" alt="David Navrátil" loading="lazy" />
        </div>
      </div>
      <div class="about-content">
        <div class="section-tag">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          {t('about.title')}
        </div>
        <p class="about-lead">{t('about.lead')}</p>
        <p class="about-text">{t('about.text')}</p>
        <div class="about-pillars">
          <div class="pillar">
            <div class="pillar-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
            </div>
            <div>
              <h3>{t('about.pillar1.title')}</h3>
              <p set:html={t('about.pillar1.desc')} />
            </div>
          </div>
          <div class="pillar">
            <div class="pillar-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            </div>
            <div>
              <h3>{t('about.pillar2.title')}</h3>
              <p>{t('about.pillar2.desc.pre')}<a href="https://davidnavratil.substack.com" target="_blank" rel="noopener">{t('about.pillar2.link')}</a>{t('about.pillar2.desc.post')}</p>
            </div>
          </div>
          <div class="pillar">
            <div class="pillar-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            </div>
            <div>
              <h3>{t('about.pillar3.title')}</h3>
              <p set:html={t('about.pillar3.desc')} />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== CONTACT ========== -->
  <section class="contact container" id="kontakt">
    <div class="contact-card reveal">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>{t('contact.title')}</h2>
          <p>{t('contact.desc')}</p>
          <div class="contact-links">
            <a href="mailto:davidxnavratil@gmail.com" class="contact-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              {t('contact.email')}
            </a>
            <a href="https://davidnavratil.substack.com" target="_blank" rel="noopener" class="contact-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
              {t('contact.newsletter')}
            </a>
            <a href="https://www.linkedin.com/in/david-navratil/" target="_blank" rel="noopener" class="contact-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              {t('contact.linkedin')}
            </a>
          </div>
        </div>
        <form action="https://formspree.io/f/xwvwvrqy" method="POST" class="contact-form">
          <div class="form-row">
            <label>
              <span>{t('form.name')}</span>
              <input type="text" name="name" required />
            </label>
            <label>
              <span>{t('form.email')}</span>
              <input type="email" name="email" required />
            </label>
          </div>
          <label>
            <span>{t('form.company')}</span>
            <input type="text" name="company" />
          </label>
          <label>
            <span>{t('form.message')}</span>
            <textarea name="message" rows="4" required></textarea>
          </label>
          <button type="submit" class="form-submit">
            {t('form.submit')}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </form>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    padding-top: 5rem;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(color-mix(in srgb, var(--color-border) 40%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--color-border) 40%, transparent) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black 30%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black 30%, transparent 70%);
  }
  .hero-glow {
    position: absolute;
    top: 10%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 500px;
    background: radial-gradient(ellipse, var(--color-accent-glow) 0%, transparent 70%);
    filter: blur(40px);
    pointer-events: none;
  }
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), var(--color-accent-glow), transparent 40%);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .hero:hover::after {
    opacity: 1;
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-xl);
    align-items: center;
  }
  .hero-content {
    max-width: 600px;
  }
  .hero-role {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
    letter-spacing: 0.01em;
  }
  .role-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #22C55E;
    animation: pulse-glow 2s ease-in-out infinite;
  }
  .hero-title {
    margin-bottom: var(--space-md);
  }
  .gradient-text {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-sub {
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    max-width: 520px;
    margin-bottom: var(--space-lg);
    line-height: 1.7;
  }
  .hero-cta {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  /* Hero photo */
  .hero-photo-wrap {
    position: relative;
    flex-shrink: 0;
  }
  .hero-photo {
    position: relative;
    width: 320px;
    height: 320px;
    border-radius: 24px;
    overflow: hidden;
    border: 2px solid var(--color-border);
    box-shadow: 0 25px 60px rgba(0,0,0,0.12);
  }
  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .photo-accent {
    position: absolute;
    bottom: -12px;
    right: -12px;
    width: 120px;
    height: 120px;
    border-radius: 20px;
    background: var(--gradient-accent);
    opacity: 0.15;
    z-index: -1;
    filter: blur(2px);
  }

  /* Buttons */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
    background: var(--gradient-accent);
    color: white;
    font-weight: 600;
    font-size: 0.95rem;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 15px var(--color-accent-glow);
    text-decoration: none;
  }
  .btn-primary:hover {
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px var(--color-accent-glow);
  }
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-weight: 500;
    font-size: 0.95rem;
    transition: border-color 0.2s, background 0.2s;
    text-decoration: none;
  }
  .btn-secondary:hover {
    color: var(--color-text);
    border-color: var(--color-accent);
    background: var(--color-surface-elevated);
  }

  /* ===== TRUST BAR ===== */
  .trust-bar {
    padding: var(--space-lg) 0 var(--space-md);
  }
  .trust-label {
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    margin-bottom: var(--space-md);
  }
  .trust-logos {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
    row-gap: var(--space-xs);
  }
  .trust-logo {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--color-text);
    opacity: 0.35;
    transition: opacity 0.3s;
    padding: 0.25rem 0;
    white-space: nowrap;
  }
  .trust-logo:hover {
    opacity: 0.7;
  }
  .trust-logo-sep {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-muted);
    opacity: 0.3;
    margin: 0 var(--space-sm);
    flex-shrink: 0;
  }

  /* ===== METRICS ===== */
  .metrics {
    margin-bottom: var(--space-2xl);
  }
  .metrics-grid {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-xl);
    padding: var(--space-lg) var(--space-xl);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: 0 4px 30px rgba(0,0,0,0.04);
  }
  .metric {
    text-align: center;
  }
  .metric-value {
    display: block;
    font-family: var(--font-serif);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .metric-label {
    font-size: 0.85rem;
    color: var(--color-muted);
  }
  .metric-divider {
    width: 1px;
    height: 3rem;
    background: var(--color-border);
  }

  /* ===== SECTION COMMON ===== */
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }
  .section-header {
    margin-bottom: var(--space-xl);
  }
  .section-header h2 {
    max-width: 600px;
  }

  /* ===== ANALYSES ===== */
  .analyses {
    margin-bottom: var(--space-2xl);
  }

  /* Featured analysis */
  .analysis-featured {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 0;
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, var(--color-border));
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .analysis-featured:hover {
    color: var(--color-text);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.1);
  }
  .featured-visual {
    position: relative;
    min-height: 280px;
    overflow: hidden;
    background: var(--color-surface-elevated);
  }
  .featured-screenshot {
    width: 100%;
    height: 100%;
  }
  .featured-screenshot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .featured-screenshot img[src=""],
  .featured-screenshot img:not([src]) {
    display: none;
  }
  .featured-visual {
