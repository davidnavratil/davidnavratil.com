---
import Base from '../layouts/Base.astro';
import HeroSection from './HeroSection.astro';
import TrustBar from './TrustBar.astro';
import AnalysesSection from './AnalysesSection.astro';
import WhyPeopleReturn from './WhyPeopleReturn.astro';
import NewsletterCTA from './NewsletterCTA.astro';
import LatestArticles from './LatestArticles.astro';
import AboutSection from './AboutSection.astro';
import SpeakingSection from './SpeakingSection.astro';
import ContactSection from './ContactSection.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations(Astro.currentLocale);
---

<Base title={t('meta.title')} description={t('meta.description')}>

  <HeroSection />
  <TrustBar />
  <AnalysesSection />
  <WhyPeopleReturn />
  <NewsletterCTA />
  <LatestArticles />
  <AboutSection />
  <SpeakingSection />
  <ContactSection />

</Base>

<style is:global>
  /* ===== BAND (alternating bg) ===== */
  .band {
    background: var(--color-band);
  }

  /* ===== SCROLL ANIMATIONS ===== */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .reveal.in-view {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
</style>

<script is:inline>
  // Scroll-triggered reveal animations
  (function() {
    var els = document.querySelectorAll('.reveal');
    if (!els.length) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('in-view');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
    els.forEach(function(el) { observer.observe(el); });
  })();
</script>
