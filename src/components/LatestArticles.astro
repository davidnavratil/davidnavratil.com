---
import { useTranslations } from '../i18n/utils';
import fs from 'node:fs';
import path from 'node:path';

const t = useTranslations(Astro.currentLocale);

// Fetch RSS at build time with fallback to cached data
interface RawArticle {
  title: string;
  link: string;
  pubDate: string;
  description: string;
  image: string;
}

interface Article {
  title: string;
  link: string;
  date: string;
  description: string;
  image: string;
}

const CACHE_PATH = path.join(process.cwd(), 'src', 'data', 'articles-cache.json');

function parseRSS(xml: string): RawArticle[] {
  const items = xml.split('<item>').slice(1, 7);
  return items.map((item) => {
    const getTag = (tag: string) => {
      const match = item.match(new RegExp(`<${tag}><!\\[CDATA\\[([\\s\\S]*?)\\]\\]></${tag}>`))
        || item.match(new RegExp(`<${tag}>([\\s\\S]*?)</${tag}>`));
      return match ? match[1].trim() : '';
    };

    const rawDesc = getTag('description');
    const cleanDesc = rawDesc
      .replace(/&#(\d+);/g, (_: string, n: string) => String.fromCharCode(parseInt(n)))
      .replace(/<[^>]+>/g, '')
      .slice(0, 160)
      .trim();

    const encMatch = item.match(/<enclosure[^>]+url="([^"]+)"/);
    let image = encMatch ? encMatch[1] : '';
    if (image && image.includes('substackcdn.com')) {
      image = image.replace(/,f_auto/, ',w_400,h_220,c_fill,f_auto');
    }

    return {
      title: getTag('title'),
      link: getTag('link'),
      pubDate: getTag('pubDate'),
      description: cleanDesc + (cleanDesc.length >= 157 ? '…' : ''),
      image,
    };
  });
}

function formatArticles(raw: RawArticle[], locale: string | undefined): Article[] {
  return raw.map(a => ({
    ...a,
    date: a.pubDate ? new Date(a.pubDate).toLocaleDateString(
      locale === 'en' ? 'en-US' : 'cs-CZ',
      { day: 'numeric', month: 'long', year: 'numeric' }
    ) : '',
  }));
}

let articles: Article[] = [];

// Try live fetch first
let rawArticles: RawArticle[] = [];
try {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 8000);
  const res = await fetch('https://davidnavratil.substack.com/feed', {
    signal: controller.signal,
    headers: { 'User-Agent': 'Mozilla/5.0 (davidnavratil.com; RSS reader)' },
  });
  clearTimeout(timeout);
  if (res.ok) {
    rawArticles = parseRSS(await res.text());
    // Save cache for future builds where fetch might fail
    try {
      fs.mkdirSync(path.dirname(CACHE_PATH), { recursive: true });
      fs.writeFileSync(CACHE_PATH, JSON.stringify(rawArticles, null, 2));
    } catch { /* cache write is best-effort */ }
  }
} catch {
  // Fetch failed — try cached data
}

// Fallback to cache if fetch failed
if (rawArticles.length === 0) {
  try {
    rawArticles = JSON.parse(fs.readFileSync(CACHE_PATH, 'utf-8'));
  } catch { /* no cache available */ }
}

articles = formatArticles(rawArticles, Astro.currentLocale);
---

{articles.length > 0 && (
  <section class="latest-articles container" id="articles">
    <div class="articles-header reveal">
      <div class="section-tag">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        {t('articles.subtitle')}
      </div>
      <h2>{t('articles.title')}</h2>
    </div>
    <div class="articles-grid reveal">
      {articles.map((article) => (
        <a href={article.link} target="_blank" rel="noopener" class="article-card">
          {article.image && (
            <div class="article-image">
              <img src={article.image} alt="" loading="lazy" width="400" height="220" />
            </div>
          )}
          <div class="article-body">
          <time class="article-date">{article.date}</time>
          <h3 class="article-title">{article.title}</h3>
          <p class="article-desc">{article.description}</p>
          <span class="article-link">
            {t('articles.read')}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
          </span>
          </div>
        </a>
      ))}
    </div>
    <div class="articles-footer reveal">
      <a href="https://davidnavratil.substack.com" target="_blank" rel="noopener" class="articles-all">
        {t('articles.cta')}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>
)}

<style>
  .latest-articles {
    margin-bottom: var(--space-2xl);
  }
  .articles-header {
    margin-bottom: var(--space-lg);
  }
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-section-tag);
    margin-bottom: var(--space-xs);
  }
  .articles-header h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    color: var(--color-text);
    line-height: 1.3;
  }
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }
  .article-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    text-decoration: none;
    overflow: hidden;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .article-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent);
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }
  .article-image {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--color-band);
  }
  .article-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .article-card:hover .article-image img {
    transform: scale(1.03);
  }
  .article-body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  .article-date {
    font-size: 0.78rem;
    color: var(--color-muted);
    margin-bottom: 0.4rem;
  }
  .article-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }
  .article-desc {
    font-size: 0.88rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    flex-grow: 1;
    margin-bottom: 0.75rem;
  }
  .article-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-accent);
  }
  .articles-footer {
    text-align: center;
  }
  .articles-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s;
  }
  .articles-all:hover {
    color: var(--color-accent-hover);
  }

  @media (max-width: 640px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
    .article-card {
      padding: var(--space-sm);
    }
  }
</style>
