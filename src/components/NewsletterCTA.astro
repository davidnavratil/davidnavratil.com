---
import { useTranslations } from '../i18n/utils';

const t = useTranslations(Astro.currentLocale);
---

<section class="newsletter container reveal" id="newsletter">
  <div class="newsletter-card">
    <div class="newsletter-glow"></div>
    <div class="newsletter-content">
      <h2 class="newsletter-heading">{t('newsletter.title')}</h2>
      <p class="newsletter-lead">{t('newsletter.desc')}</p>
      <ul class="newsletter-values">
        <li>
          <svg class="check-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{t('newsletter.value1')}</span>
        </li>
        <li>
          <svg class="check-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{t('newsletter.value2')}</span>
        </li>
        <li>
          <svg class="check-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{t('newsletter.value3')}</span>
        </li>
        <li>
          <svg class="check-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{t('newsletter.value4')}</span>
        </li>
        <li>
          <svg class="check-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{t('newsletter.value5')}</span>
        </li>
      </ul>
      <div class="newsletter-form-wrap">
        <a href="https://davidnavratil.substack.com/subscribe" target="_blank" rel="noopener" class="newsletter-btn">
          {t('newsletter.cta')}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <p class="newsletter-note">{t('newsletter.note')}</p>
    </div>
  </div>
</section>

<style>
  .newsletter {
    margin-bottom: var(--space-3xl);
  }
  .newsletter-card {
    position: relative;
    padding: var(--space-2xl) var(--space-xl);
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 8%, var(--color-surface)), color-mix(in srgb, var(--color-accent) 3%, var(--color-surface)));
    border: 1px solid color-mix(in srgb, var(--color-accent) 25%, var(--color-border));
    overflow: hidden;
  }
  .newsletter-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, var(--color-accent-glow), transparent 70%);
    pointer-events: none;
  }
  .newsletter-content {
    position: relative;
    max-width: 600px;
    margin-inline: auto;
  }
  .newsletter-heading {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    line-height: 1.3;
    text-align: center;
    margin-bottom: var(--space-md);
  }
  .newsletter-lead {
    color: var(--color-muted);
    text-align: center;
    max-width: 500px;
    margin-inline: auto;
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }
  .newsletter-values {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-xl) 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 400px;
    margin-inline: auto;
  }
  .newsletter-values li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--color-text);
  }
  .check-icon {
    flex-shrink: 0;
    color: var(--color-accent);
  }
  .newsletter-form-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-sm);
  }
  .newsletter-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 2.5rem;
    border-radius: 10px;
    background: var(--gradient-accent);
    color: white;
    font-weight: 600;
    font-size: 1.05rem;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 20px var(--color-accent-glow);
    text-decoration: none;
    width: auto;
  }
  .newsletter-btn:hover {
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px var(--color-accent-glow);
  }
  .newsletter-note {
    font-size: 0.8rem;
    color: var(--color-muted);
    text-align: center;
    margin-top: var(--space-sm);
  }

  @media (max-width: 640px) {
    .newsletter-card {
      padding: var(--space-xl) var(--space-md);
    }
    .newsletter-heading {
      font-size: 1.4rem;
    }
    .newsletter-btn {
      width: 100%;
      min-height: 44px;
    }
    .newsletter-form-wrap {
      padding-inline: 0;
    }
    .newsletter-lead {
      font-size: 0.95rem;
    }
  }

  @media (max-width: 400px) {
    .newsletter-card {
      padding: var(--space-lg) var(--space-sm);
    }
    .newsletter-heading {
      font-size: 1.25rem;
    }
    .newsletter-values li {
      font-size: 0.9rem;
    }
  }
</style>
