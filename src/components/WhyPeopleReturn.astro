---
import { useTranslations } from '../i18n/utils';

const t = useTranslations(Astro.currentLocale);
---

<section class="why-return band" id="why">
  <div class="container">
    <h2 class="why-return__title reveal" set:html={t('return.title')} />

    <div class="why-return__grid reveal">
      <div class="why-return__card">
        <div class="why-return__icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <circle cx="12" cy="12" r="6" />
            <circle cx="12" cy="12" r="2" />
            <line x1="12" y1="2" x2="12" y2="4" />
            <line x1="12" y1="20" x2="12" y2="22" />
            <line x1="2" y1="12" x2="4" y2="12" />
            <line x1="20" y1="12" x2="22" y2="12" />
          </svg>
        </div>
        <h3 class="why-return__card-title">{t('return.item1.title')}</h3>
        <p class="why-return__card-desc" set:html={t('return.item1.desc')} />
      </div>

      <div class="why-return__card">
        <div class="why-return__icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="1" />
            <line x1="3" y1="9" x2="21" y2="9" />
            <line x1="3" y1="15" x2="21" y2="15" />
            <line x1="9" y1="3" x2="9" y2="21" />
            <line x1="15" y1="3" x2="15" y2="21" />
          </svg>
        </div>
        <h3 class="why-return__card-title">{t('return.item2.title')}</h3>
        <p class="why-return__card-desc" set:html={t('return.item2.desc')} />
      </div>

      <div class="why-return__card">
        <div class="why-return__icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" />
            <polyline points="16 7 22 7 22 13" />
          </svg>
        </div>
        <h3 class="why-return__card-title">{t('return.item3.title')}</h3>
        <p class="why-return__card-desc" set:html={t('return.item3.desc')} />
      </div>
    </div>
  </div>
</section>

<style>
  .why-return {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
  }

  .why-return__title {
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight: 700;
    text-align: center;
    color: var(--color-text);
    max-width: 640px;
    margin: 0 auto var(--space-xl);
    line-height: 1.35;
  }

  .why-return__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .why-return__card {
    padding: var(--space-lg);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .why-return__icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-sm);
    color: var(--color-navy);
  }

  .why-return__card-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.35rem;
  }

  .why-return__card-desc {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-muted);
  }

  @media (max-width: 900px) {
    .why-return__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }
  }

  @media (max-width: 640px) {
    .why-return {
      padding-top: var(--space-lg);
      padding-bottom: var(--space-lg);
    }
    .why-return__grid {
      max-width: 100%;
      gap: var(--space-sm);
    }
    .why-return__card {
      padding: var(--space-md);
    }
    .why-return__card-desc {
      font-size: 0.9rem;
    }
  }
</style>
